#!/usr/bin/env bash
# Local mirror of the commitlint CI check (PR titles), applied to commit
# messages. Zero dependencies — same regex as .github/workflows/commitlint.yml.
# With squash-only merges only the PR title reaches main, so this is a
# courtesy check that keeps branch history readable, not a gate.
set -euo pipefail

MSG_FILE="$1"
FIRST_LINE="$(head -n1 "$MSG_FILE")"

# Merge/revert/fixup commits are exempt.
case "$FIRST_LINE" in
  Merge\ *|Revert\ *|fixup!\ *|squash!\ *) exit 0 ;;
esac

if ! echo "$FIRST_LINE" | grep -Eq '^(feat|fix|perf|refactor|docs|test|build|ci|chore|revert|style)(\([a-z0-9._/-]+\))?!?: .+'; then
  echo "commit-msg: first line must follow Conventional Commits," >&2
  echo "  e.g. 'feat(api): add version endpoint'" >&2
  echo "  got: $FIRST_LINE" >&2
  exit 1
fi
